{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "export",
  "description": "Capability for the export notes pop-out window",
  "windows": ["export-notes-*"],
  "permissions": [
    "core:default",
    "store:default",
    "fs:default",
    "fs:allow-document-read-recursive",
    "fs:allow-document-write-recursive",
    "fs:allow-mkdir",
    "opener:default",
    "opener:allow-open-path"
  ]
}
